# Kirin Pair Environment Variables
# Copy to .env and fill in the values

# JWT Secret for authentication (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# API Key for agents authentication (REQUIRED in production)
# Set KIRIN_REQUIRE_AUTH=false only for local development
KIRIN_REQUIRE_AUTH=true
API_KEY=

# Rate limiting (requests per minute per client)
RATE_LIMIT_PER_MINUTE=60

# CRM Configuration (choose one provider)
CRM_PROVIDER=  # notion, airtable, or nocodb

# Notion CRM
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Airtable CRM
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# NocoDB CRM
NOCODB_URL=
NOCODB_TOKEN=

# Kirin Platform URL (the existing kirin-platform agents service)
KIRIN_PLATFORM_URL=http://agents:8000

# LiteLLM URL (provided by the kirin-platform stack)
LITELLM_URL=http://litellm:4000

# Whisper Service URL (will be provided by kirin-pair whisper-service)
WHISPER_URL=http://whisper-service:8003

# Output directory for processed media (inside the worker container)
OUTPUT_DIR=/app/output

# Redis Password (if set, otherwise leave blank)
REDIS_PASSWORD=

# API Keys for LiteLLM (these are already set in the kirin-platform stack, but we may need them for direct calls if needed)
# Note: The kirin-pair-backend will primarily call the kirin-platform agents, which in turn use LiteLLM.
# However, if we want to call LiteLLM directly from kirin-pair, we need these keys.
# For now, we rely on the kirin-platform agents for LLM calls, so we can leave these blank or copy from the kirin-platform .env.
QWEN_VL_MAX_API_KEY=your_qwen_vl_max_api_key_here
DEEPSEEK_CHAT_API_KEY=your_deepseek_chat_api_key_here
MOONSHOT_V1_128K_API_KEY=your_moonshot_v1_128k_api_key_here

# Note: The following are already defined in the kirin-platform stack and are reused:
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=kirin
# POSTGRES_USER=kirin
# POSTGRES_PASSWORD=kirinpass
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# REDIS_HOST=redis
# REDIS_PORT=6379
