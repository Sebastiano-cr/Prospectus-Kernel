FROM python:3.13-slim

# Install system dependencies including ffmpeg for video processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the application code
COPY . .

# Set the PYTHONPATH to include the parent directory (so we can import agents)
ENV PYTHONPATH="/app:/app/.."

# Expose the port the app runs on (if any, worker might not expose a port)
# We'll leave it unset for now, but if we need to expose for health checks, we can.
# EXPOSE 8004

# Command to run the worker (we'll create a simple script that listens to Redis queue)
# For now, we'll just sleep to keep the container alive for development.
# In production, this should be replaced with the actual worker process.
CMD ["python", "worker.py"]