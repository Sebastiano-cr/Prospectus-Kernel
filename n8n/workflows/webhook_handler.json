{
  "name": "Webhook Handler - WhatsApp Response Processing",
  "nodes": [
    {
      "parameters": {
        "path": "whatsapp-webhook",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "responseData": {
          "statusCode": 200,
          "contentType": "text/plain",
          "body": "ok"
        }
